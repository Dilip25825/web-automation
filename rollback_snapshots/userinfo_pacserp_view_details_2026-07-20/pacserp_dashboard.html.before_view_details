{% extends 'core/base.html' %}

{% block title %}
EPR
{% endblock %}

{% block content %}
<style>
    @keyframes appModalIn {
        from {
            opacity: 0;
            transform: translateY(18px) scale(0.97);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .erp-activation-swal-popup {
        animation: appModalIn 0.24s ease-out both;
        width: min(580px, calc(100vw - 24px)) !important;
        max-width: calc(100vw - 24px) !important;
        box-sizing: border-box !important;
        border-radius: 16px !important;
        overflow: hidden;
        padding: 0 0 1.25rem !important;
    }

    .erp-activation-swal-popup .swal2-html-container {
        margin: 0 !important;
        padding: 0 !important;
    }

    .erp-activation-swal-popup .swal2-input {
        width: 100% !important;
        max-width: 100% !important;
        box-sizing: border-box !important;
        margin: 0 !important;
    }

    .erp-activation-swal-popup .activation-dialog-header {
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        padding: 1.15rem 1.4rem;
        text-align: left;
    }

    .erp-activation-swal-popup .activation-dialog-header h3 {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 800;
    }

    .erp-activation-swal-popup .activation-dialog-header p {
        margin: 0.25rem 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }

    .erp-activation-swal-popup .activation-dialog-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        padding: 1.15rem 1.4rem 0.75rem;
        text-align: left;
    }

    .erp-activation-swal-popup .activation-dialog-detail {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.65rem;
        padding: 0.65rem 0.75rem;
    }

    .erp-activation-swal-popup .activation-dialog-detail span {
        color: #64748b;
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .erp-activation-swal-popup .activation-dialog-detail strong {
        color: #0f172a;
        display: block;
        margin-top: 0.2rem;
        overflow-wrap: anywhere;
    }

    .erp-activation-swal-popup .activation-dialog-fields {
        padding: 0.25rem 1.4rem 0;
        text-align: left;
    }

    .erp-activation-swal-popup .activation-dialog-fields label {
        color: #334155;
        display: block;
        font-size: 0.84rem;
        font-weight: 700;
        margin: 0.8rem 0 0.3rem;
    }

    .erp-activation-swal-popup .activation-dialog-fields .swal2-input {
        margin: 0 0 0.25rem !important;
    }

    .erp-form-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1050;
        background: rgba(15, 23, 42, 0.62);
        padding: 1rem;
        overflow-y: auto;
    }

    .erp-form-modal.is-open {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        animation: appModalIn 0.24s ease-out both;
    }

    .erp-form-dialog {
        animation: appModalIn 0.24s ease-out both;
        width: min(820px, 100%);
        margin: 1rem auto;
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.3);
        overflow: hidden;
    }

    .erp-form-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.35rem;
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
    }

    .erp-form-header h3 {
        margin: 0;
        font-size: 1.15rem;
        font-weight: 800;
    }

    .erp-form-close {
        border: 0;
        background: transparent;
        color: #fff;
        font-size: 2rem;
        cursor: pointer;
    }

    .erp-form-body {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        padding: 1.35rem;
        max-height: 68vh;
        overflow-y: auto;
    }

    .erp-field label {
        display: block;
        color: #334155;
        font-size: 0.78rem;
        font-weight: 800;
        margin-bottom: 0.3rem;
        text-transform: uppercase;
    }

    .erp-field input,
    .erp-field select,
    .erp-field textarea {
        width: 100% !important;
        box-sizing: border-box;
        background: #fff !important;
        color: #172033 !important;
        border: 1px solid #cbd5e1 !important;
    }

    .erp-form-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.6rem;
        padding: 1rem 1.35rem;
        border-top: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    @media (max-width: 640px) {
        .erp-form-body {
            grid-template-columns: 1fr;
            max-height: 70vh;
        }

        .erp-form-modal {
            padding: 0.4rem;
        }

        .erp-activation-swal-popup .activation-dialog-details {
            grid-template-columns: 1fr;
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .erp-activation-swal-popup .activation-dialog-fields {
            padding-left: 1rem;
            padding-right: 1rem;
        }
    }

    .modal.fade {
        display: none !important;
    }

    .erp-activation-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1060;
        background: rgba(15, 23, 42, 0.62);
        padding: 1rem;
        overflow-y: auto;
    }

    .erp-activation-modal.is-open {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        animation: appModalIn 0.24s ease-out both;
    }

    .erp-activation-dialog {
        width: min(620px, 100%);
        margin: 1rem auto;
        background: #fff;
        border-radius: 1rem;
        box-shadow: 0 24px 70px rgba(15, 23, 42, 0.3);
        overflow: hidden;
        animation: appModalIn 0.24s ease-out both;
    }

    .erp-activation-header {
        padding: 1rem 1.35rem;
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
    }

    .erp-activation-header h3 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
    }

    .erp-activation-header p {
        margin: 0.2rem 0 0;
        opacity: 0.9;
    }

    .erp-activation-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        padding: 1.2rem 1.35rem 0.8rem;
    }

    .erp-activation-detail {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.65rem;
        padding: 0.65rem 0.75rem;
    }

    .erp-activation-detail span {
        display: block;
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .erp-activation-detail strong {
        display: block;
        color: #0f172a;
        margin-top: 0.2rem;
        overflow-wrap: anywhere;
    }

    .erp-activation-fields {
        padding: 0.2rem 1.35rem 1rem;
    }

    .erp-activation-fields label {
        display: block;
        color: #334155;
        font-size: 0.8rem;
        font-weight: 800;
        margin: 0.7rem 0 0.3rem;
    }

    .erp-activation-fields input {
        width: 100% !important;
        box-sizing: border-box;
        background: #fff !important;
        color: #172033 !important;
        border: 1px solid #cbd5e1 !important;
        border-radius: 0.5rem;
        padding: 0.65rem 0.75rem;
    }

    .erp-activation-footer {
        display: flex;
        justify-content: flex-end;
        gap: 0.6rem;
        padding: 1rem 1.35rem;
        border-top: 1px solid #e2e8f0;
        background: #f8fafc;
    }

    @media (max-width: 560px) {
        .erp-activation-details {
            grid-template-columns: 1fr;
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .erp-activation-fields {
            padding-left: 1rem;
            padding-right: 1rem;
        }

        .erp-activation-footer {
            padding-left: 1rem;
            padding-right: 1rem;
        }
    }

